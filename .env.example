# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.probooksolutions.com

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-MLHTJEZ3ZS
# Your Google Analytics 4 measurement ID
# If not set, defaults to G-MLHTJEZ3ZS
# Vercel Analytics is also enabled by default when deployed to Vercel

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=no-reply@probooksolutions.com
CONTACT_INBOX=contact@probooksolutions.com

# CRM Integration (choose one)
CRM_PROVIDER=hubspot
# Options: 'hubspot' or 'pipedrive' or leave empty to disable

# HubSpot Configuration (if CRM_PROVIDER=hubspot)
HUBSPOT_API_KEY=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Alternative: HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_PIPELINE_ID=default
HUBSPOT_DEALSTAGE_ID=appointmentscheduled

# Pipedrive Configuration (if CRM_PROVIDER=pipedrive)
# PIPEDRIVE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PIPEDRIVE_COMPANY_DOMAIN=yourcompany

# Firebase (Primary Backend)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"probooksolution-xxxxx","private_key_id":"xxxxx","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@probooksolution-xxxxx.iam.gserviceaccount.com","client_id":"xxxxx","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40probooksolution-xxxxx.iam.gserviceaccount.com"}
# Get from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Copy the entire JSON object (single line, no line breaks)

# Database (Supabase) - Optional fallback
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey...

# File Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# Chat/AI Integration
CHAT_PROVIDER=openai
# Options: 'openai' or 'deepseek'
CHAT_DEMO_MODE=false
# Set to 'true' or '1' to use canned responses instead of real AI

# OpenAI Configuration (if CHAT_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
# Use gpt-5-nano or gpt-4o-mini for cost-effective chat
OPENAI_USE_RESPONSES_API=0
# Set to '1' to force Responses API (for gpt-5+ models)

# DeepSeek Configuration (if CHAT_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Scheduling Integration
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/consultation

# Security & Rate Limiting (recommended for production)
# Add via Vercel Edge Config or external service
# RATE_LIMIT_REQUESTS_PER_MINUTE=10

# CMS Admin Panel
NEXT_PUBLIC_ADMIN_PASSWORD=probook2025admin
# Change this to a secure password in production!
# Used for /admin access

# Environment
NODE_ENV=production
# Set to 'development' for local dev
