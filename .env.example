# ===============================================
# ProBook Solutions - Environment Variables
# ===============================================
# Copy this file to .env.local and fill in your values

# -----------------------------------------------
# 🌐 SITE CONFIGURATION
# -----------------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.probooksolutions.com

# -----------------------------------------------
# 🔐 ADMIN AUTHENTICATION
# -----------------------------------------------
# Set a strong password for CMS access (minimum 12 characters recommended)
NEXT_PUBLIC_ADMIN_PASSWORD=your-secure-admin-password-here
NEXT_PUBLIC_ADMIN_TOKEN=

# -----------------------------------------------
# 📧 EMAIL CONFIGURATION (Resend)
# -----------------------------------------------
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=no-reply@probooksolutions.com
CONTACT_INBOX=info@probooksolutions.org

# -----------------------------------------------
# 🗄️ DATABASE (Supabase)
# -----------------------------------------------
# These are auto-configured by Vercel when you connect Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres connection strings (auto-configured by Vercel)
POSTGRES_URL=postgres://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
POSTGRES_PRISMA_URL=postgres://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
POSTGRES_HOST=aws-0-us-east-1.pooler.supabase.com
POSTGRES_USER=postgres.[PROJECT-ID]
POSTGRES_DATABASE=postgres

# -----------------------------------------------
# 📦 FILE STORAGE (Vercel Blob)
# -----------------------------------------------
# Get from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# -----------------------------------------------
# 🔥 FIREBASE (Optional - for additional storage/database)
# -----------------------------------------------
# Paste your entire Firebase service account JSON as a single line
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# -----------------------------------------------
# 🚦 RATE LIMITING (Upstash Redis - Optional)
# -----------------------------------------------
# If not provided, falls back to in-memory rate limiting
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://xxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------
# 📊 ANALYTICS
# -----------------------------------------------
# Google Analytics 4
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google Search Console verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# -----------------------------------------------
# 💼 CRM INTEGRATION (Optional)
# -----------------------------------------------
# Set CRM_PROVIDER to 'hubspot' or 'pipedrive' (or leave empty to disable)
CRM_PROVIDER=

# HubSpot Configuration
HUBSPOT_API_KEY=
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PIPELINE_ID=
HUBSPOT_DEALSTAGE_ID=

# Pipedrive Configuration
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=your-company

# -----------------------------------------------
# 🤖 AI CHAT (Optional)
# -----------------------------------------------
# Set CHAT_PROVIDER to 'openai' or 'deepseek' (or leave empty/use CHAT_DEMO_MODE)
CHAT_PROVIDER=openai
CHAT_DEMO_MODE=false

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx

# DeepSeek Configuration (cost-effective alternative)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------
# 🔒 SECURITY
# -----------------------------------------------
# CSRF Token Secret (generate a random 32-character string)
CSRF_SECRET=generate-a-random-32-character-string-here

# Session Secret (generate a random 32-character string)
SESSION_SECRET=another-random-32-character-string-here

# -----------------------------------------------
# 🌍 LOCALIZATION
# -----------------------------------------------
# Default locale for the site (en or ar)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# -----------------------------------------------
# 📈 MONITORING & ERROR TRACKING (Optional)
# -----------------------------------------------
# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=

# LogRocket for session replay
NEXT_PUBLIC_LOGROCKET_ID=

# -----------------------------------------------
# 🎯 MARKETING & SCHEDULING
# -----------------------------------------------
# Calendly username for consultation booking
NEXT_PUBLIC_CALENDLY_USERNAME=probooksolutions

# -----------------------------------------------
# 🧪 DEVELOPMENT
# -----------------------------------------------
# Set to 'true' to show development banner
NEXT_PUBLIC_DEV_MODE=false

# ===============================================
# SETUP INSTRUCTIONS
# ===============================================
# 
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in all required values (marked with 'your-' prefixes)
# 3. Never commit .env.local to git (already in .gitignore)
# 4. For Vercel deployment, add these as Environment Variables in:
#    https://vercel.com/[your-team]/[your-project]/settings/environment-variables
# 5. Generate random secrets for CSRF_SECRET and SESSION_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ===============================================
# SECURITY NOTES
# ===============================================
#
# ⚠️  CRITICAL: Never expose these in client-side code
# ⚠️  Only use NEXT_PUBLIC_ prefix for truly public values
# ⚠️  Rotate API keys regularly (every 90 days recommended)
# ⚠️  Use different passwords for dev/staging/production
# ⚠️  Enable 2FA on all third-party service accounts
#
# ===============================================
